# Core DB
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cms_core

# Content Plugin DB
CONTENT_DATABASE_URL=postgresql://postgres:postgres@localhost:5433/content_db

# Redis
REDIS_URL=redis://localhost:6379

# JWT — production'da mutlaka değiştir
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-refresh-in-production

# Server
HTTP_PORT=3000
GRPC_PORT=50051
LOG_LEVEL=info
NODE_ENV=development

# CORS (production'da admin URL'ini belirt)
CORS_ORIGIN=http://localhost:5173
